{
  "name": "samp-mcp",
  "version": "1.0.5",
  "description": "An MCP server for Managing SAMP (San Andreas Multiplayer) servers with Thai (Windows-874) support.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "samp-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "samp",
    "sa-mp",
    "mcp",
    "modelcontextprotocol",
    "pawn",
    "rcon",
    "windows-874",
    "thai"
  ],
  "author": "Watcharapong Namsaeng",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "iconv-lite": "^0.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/iconv-lite": "^0.0.1",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
